# Vercel / production frontend — set in hosting dashboard (Netlify, etc.)
# Same-origin API (no CORS issues when site and API share one domain)
REACT_APP_API_URL=/api

# Local dev: leave REACT_APP_API_URL unset or use /api — the app auto-targets
# http://localhost:4000/api on localhost, and setupProxy.js forwards /api too.
# Run `npm run server:dev` in a second terminal alongside `npm start`.
