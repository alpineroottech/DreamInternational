# Copy to server/.env for local development

# ─── Database (Neon PostgreSQL) ───────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Optional: your local React dev URL
CLIENT_ORIGIN="http://localhost:3000"

# ─── Supabase Storage (images) ──────────────────────────────
# Project Settings → API in Supabase dashboard
SUPABASE_URL="https://xxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-never-expose-in-frontend"
SUPABASE_STORAGE_BUCKET="Dream Media"
SUPABASE_STORAGE_FOLDER="uploads"

# ─── First-time seed (change password after deploy) ─────────
SEED_ADMIN_EMAIL="admin@dreaminternationaltours.com"
SEED_ADMIN_PASSWORD="ChangeThisPassword123!"
SEED_ADMIN_NAME="Dream Admin"

# ─── Email (Resend) ─────────────────────────────────────────
# API key: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# Sender — must be an address on a domain verified in Resend (resend.com/domains).
# flywithdream.com is already verified for this project; onboarding@resend.dev (the
# Resend sandbox address) can ONLY deliver to the account owner's own email, so using
# it here silently breaks every confirmation email sent to real visitors.
RESEND_FROM_EMAIL="Dream International Travel and Tours <noreply@flywithdream.com>"

# Where inquiry notifications are delivered (defaults to resend@flywithdream.com)
RESEND_ADMIN_EMAIL="resend@flywithdream.com"
