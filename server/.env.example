# Copy to server/.env for local development (PostgreSQL via Neon)

# Neon connection string (required)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Strong secret — min 16 characters (required in production)
JWT_SECRET="change-me-to-a-long-random-string"

# Optional: defaults to http://localhost:3000 in dev
CLIENT_ORIGIN="http://localhost:3000"

# Cloudinary (required on Netlify/serverless for CMS image uploads — free tier at cloudinary.com)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="dream-international"

# First-time seed credentials (change after deploy)
SEED_ADMIN_EMAIL="admin@dreaminternationaltours.com"
SEED_ADMIN_PASSWORD="ChangeThisPassword123!"
SEED_ADMIN_NAME="Dream Admin"
