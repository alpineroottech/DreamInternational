{
  "installCommand": "npm install && npm run prisma:generate && (node scripts/prisma-migrate-deploy-retry.mjs || echo \"Prisma migrate skipped\")",
  "buildCommand": "CI=false npm run build:web",
  "outputDirectory": "build",
  "functions": {
    "api/[...slug].mjs": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "node_modules/.prisma/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
